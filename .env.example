# ========================================
# MULTI-MODEL AI MUSIC GENERATION
# ========================================

# REQUIRED - Replicate API (for MusicGen, AudioCraft, Riffusion)
# Sign up: https://replicate.com
# Cost: ~$0.05 per song, $5 free credit to start
REPLICATE_API_TOKEN=your_replicate_token_here

# ========================================
# PROFESSIONAL MASTERING (Recommended)
# ========================================

# LANDR API - Professional mastering service
# Sign up: https://www.landr.com/api
# Cost: ~$0.10-0.20 per master
# Note: Optional - will use custom mastering if not set
LANDR_API_KEY=your_landr_key_here

# ========================================
# LYRICS GENERATION (Optional)
# ========================================

# OpenAI (GPT-4) - Best for creative lyrics
# Sign up: https://platform.openai.com
# Cost: ~$0.01-0.05 per generation
OPENAI_API_KEY=your_openai_key_here

# OR use Anthropic Claude
# Sign up: https://console.anthropic.com
# Cost: Similar to OpenAI
ANTHROPIC_API_KEY=your_anthropic_key_here

# ========================================
# ALBUM ART GENERATION (Optional)
# ========================================

# Uses OPENAI_API_KEY if set for DALL-E 3
# OR use Stability AI for Stable Diffusion
# Sign up: https://platform.stability.ai
# Cost: ~$0.02-0.08 per image
STABILITY_API_KEY=your_stability_key_here

# ========================================
# STEM SEPARATION (Optional)
# ========================================

# Lalal.ai - Cloud stem separation
# Sign up: https://www.lalal.ai/api
# Note: Optional - can use free alternatives (Spleeter, Demucs)
LALAL_AI_API_KEY=your_lalal_key_here

# Moises API - Alternative stem separation
MOISES_API_KEY=your_moises_key_here

# ========================================
# CLOUD STORAGE (Recommended for Production)
# ========================================

# AWS S3 - For storing generated audio files
# More scalable than local storage
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# OR use Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OR use Supabase Storage
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_anon_key

# ========================================
# ADVANCED AI MODELS (Optional)
# ========================================

# Hugging Face - For self-hosted or custom models
HUGGINGFACE_API_KEY=your_huggingface_key_here

# Google Cloud - For MusicLM (if available)
GOOGLE_CLOUD_API_KEY=your_google_key_here

# ========================================
# CONFIGURATION OPTIONS
# ========================================

# Environment
NODE_ENV=development

# Default model selection strategy
# Options: fastest | best-quality | ensemble-top3 | ensemble-all | adaptive
DEFAULT_GENERATION_STRATEGY=ensemble-top3

# Enable features
ENABLE_MASTERING=true
ENABLE_REFINEMENT=true
ENABLE_ANALYTICS=true

# Cost limits (optional safety)
MAX_COST_PER_GENERATION=1.00
MONTHLY_BUDGET_LIMIT=500.00

# ========================================
# GETTING STARTED
# ========================================
#
# MINIMUM SETUP:
# 1. Add REPLICATE_API_TOKEN (required for music generation)
#
# RECOMMENDED SETUP:
# 2. Add LANDR_API_KEY (for professional mastering)
# 3. Add OPENAI_API_KEY (for lyrics and album art)
#
# FULL SETUP:
# 4. Add cloud storage (AWS_* or CLOUDINARY_*)
# 5. Add stem separation API
#
# See SETUP_GUIDE.md for detailed instructions!
