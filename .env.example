# AI Music Generation API Keys
# Uncomment and add your API key for your chosen provider

# Suno API (if available)
# SUNO_API_KEY=your_suno_api_key_here

# Replicate (for MusicGen, Riffusion, etc.)
# REPLICATE_API_TOKEN=your_replicate_token_here

# Hugging Face (for self-hosted models)
# HUGGINGFACE_API_KEY=your_huggingface_key_here

# OpenAI (if using GPT for lyrics generation)
# OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude (for lyrics/creative text)
# ANTHROPIC_API_KEY=your_anthropic_key_here
